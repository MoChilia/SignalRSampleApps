<?xml version="1.0" encoding="utf-8"?>
<!-- Adds the locally-built aspnetcore feed so Microsoft.AspNetCore.Authentication.JwtBearer
     11.0.0-dev resolves. .NET 11 is still preview, so no stable 11.0.0 JwtBearer exists on
     nuget.org. See ..\refreshAuthClient\dev-setup.txt for how to pack the local packages. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local-aspnetcore" value="C:\Users\shiyingchen\aspnetcore\artifacts\packages\Debug\Shipping" />
  </packageSources>
</configuration>
